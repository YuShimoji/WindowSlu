# NuGet Packages
*.nupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/
# Uncomment if necessary however generally it will be regenerated when needed
#!**/[Pp]ackages/repositories.config
# NuGet v3's project.json file needs to be saved as it contains package dependencies
**/project.json
# NuGet v3's project.lock.json file can be ignored as it is auto-generated
**/project.lock.json

# Dotcover Code Coverage supporting files
*.dotcover

# Paket dependency manager
.paket/paket.exe
paket-files/

# FAKE - F# Make
.fake/

